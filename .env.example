# .env.example — copy to .env and fill in your values. Never commit .env.

# Environment mode: "prod" | "test" | "test_file"
APP_ENV=test_file

# OpenAI API key
OPENAI_API_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Qdrant vector store (default: local instance)
QDRANT_HOST=localhost
QDRANT_PORT=6333
